# Gemini API key (AIzaSy or AQ. prefix) — standard AI Studio route, no gcloud needed
GEMINI_API_KEY=your-api-key-here

GEMINI_MODEL=gemini-3.5-flash
# 503 高負載時自動備援至 gemini-2.5-flash（無需額外設定）

API_PORT=3001

# Frontend production build (Vite) — backend URL for Agent Rex
VITE_API_BASE_URL=https://rexxportfolio.onrender.com

# Optional: restrict CORS on the API (comma-separated origins). Default: *
# CORS_ORIGIN=https://your-static-site.onrender.com
